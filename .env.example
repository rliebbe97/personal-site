# Copy to .env.local and fill in from https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Your Substack publication base URL (no trailing slash); /words pulls <url>/feed
NEXT_PUBLIC_SUBSTACK_URL=https://yourname.substack.com

# Optional. Free key from https://www.themoviedb.org/settings/api — reliable
# cover art for shelf FILMS. Without it, films fall back to iTunes (unreliable).
TMDB_API_KEY=
